# macOS
.DS_Store

# Editor
.idea/
.vscode/
*.swp
*.swo
*~

# Logs
logs/
*.log

# Dependency directories
node_modules/
vendor/

# Build output
dist/
build/
out/

# Environment variables
.env
.env.local
.env.*.local

# kele runtime
.kele/
.kele-debug/
.kele-logs/
.plans/

# Generated projects (kele creates these for users)
# Never commit user-generated projects into kele's own repo
kele-projects/
# Exclude Chinese-named directories (user input often becomes dir names)
[一-龥]*/

# Test artifacts
coverage/

.node/
.node/

# AI 工具个人配置（不同开发者配置不同，且可能含敏感信息）
.clinerules/
.cursorrules
.kimi/

# AI 运行时数据（运行时生成，不应版本控制）
context/
memory/
